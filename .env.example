# ─── Server Configuration ────────────────────────────────────────
PORT=8080

# ─── Feature Flags ───────────────────────────────────────────────
# Set to "false" to use real Gemini-powered AI services
USE_MOCKS=true

# ─── Gemini API Key ─────────────────────────────────────────────
# Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
